<!DOCTYPE html>
<html lang="pt-br">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Editar Sobre Mim — Admin</title>
    <link href="https://fonts.googleapis.com/css2?family=JetBrains+Mono:wght@400;500;600;700&display=swap" rel="stylesheet">
    <link rel="stylesheet" href="/css/form_admin.css">
    <link rel="stylesheet" href="/css/tweaks-panel.css">
    <script src="/js/tweaks-default.js"></script>
    <style>
        .section-title {
            font-size: 0.75rem;
            font-weight: 700;
            color: var(--accent);
            margin-top: 12px;
            padding-bottom: 8px;
            border-bottom: 1px solid var(--line);
            text-transform: uppercase;
            letter-spacing: 0.08em;
        }

        .tag-container {
            display: flex;
            flex-wrap: wrap;
            gap: 8px;
            margin-top: 4px;
        }

        .tag {
            display: flex;
            align-items: center;
            gap: 6px;
            background: var(--bg-2);
            color: var(--fg-2);
            padding: 5px 10px;
            border-radius: 999px;
            font-size: 0.8rem;
            border: 1px solid var(--line-2);
        }

        .tag button {
            background: none;
            border: none;
            color: var(--red);
            cursor: pointer;
            font-size: 1rem;
            padding: 0;
            line-height: 1;
        }

        .add-row {
            display: flex;
            gap: 8px;
            margin-top: 8px;
        }

        .add-row input { flex: 1; }

        .btn-add {
            background: var(--bg-2);
            border: 1px solid var(--line-2);
            border-radius: 6px;
            color: var(--accent);
            cursor: pointer;
            font-family: var(--mono);
            font-size: 0.82rem;
            font-weight: 600;
            padding: 9px 16px;
            transition: background-color 0.15s;
            white-space: nowrap;
        }

        .btn-add:hover { background: var(--line); }

        .exp-card {
            background: var(--bg-1);
            border: 1px solid var(--line);
            border-radius: 8px;
            padding: 20px;
            margin-top: 12px;
            position: relative;
        }

        .exp-card .campo { margin-bottom: 12px; }
        .exp-card .campo:last-of-type { margin-bottom: 0; }

        .btn-remove-exp {
            position: absolute;
            top: 12px;
            right: 12px;
            background: none;
            border: 1px solid var(--red);
            border-radius: 5px;
            color: var(--red);
            cursor: pointer;
            font-size: 0.75rem;
            font-family: var(--mono);
            padding: 4px 10px;
            transition: background-color 0.15s;
        }

        .btn-remove-exp:hover { background: color-mix(in srgb, var(--red) 15%, transparent); }

        .foto-preview {
            width: 100px;
            height: 100px;
            border-radius: 50%;
            object-fit: cover;
            border: 2px solid var(--accent);
            margin-top: 8px;
        }

        .exp-grid {
            display: grid;
            grid-template-columns: 1fr 1fr;
            gap: 12px;
        }

        @media (max-width: 600px) {
            .exp-grid { grid-template-columns: 1fr; }
        }
    </style>
</head>
<body>
    <canvas id="bgfx"></canvas>

    <header class="admin-header">
        <a href="/admin" class="btn-voltar">← admin</a>
        <h1>Sobre Mim</h1>
        <button type="button" id="open-tweaks" class="btn-tweaks">⚙</button>
    </header>

    <div class="form-container">
        <form id="sobreMimForm" class="formulario" enctype="multipart/form-data">

            <!-- Foto -->
            <div class="campo">
                <label for="fotoInput">Foto de perfil</label>
                <% if (sobre && sobre.foto) { %>
                    <img src="<%= sobre.foto %>" class="foto-preview" id="fotoPreview" alt="Foto atual">
                <% } else { %>
                    <img src="" class="foto-preview" id="fotoPreview" alt="" style="display:none;">
                <% } %>
                <input name="foto" type="file" accept="image/*" id="fotoInput" class="input-file">
            </div>

            <!-- Currículo -->
            <div class="campo">
                <label for="curriculoInput">Currículo (PDF)</label>
                <% if (sobre && sobre.curriculo) { %>
                    <p style="margin:4px 0 8px;font-size:0.82rem;color:var(--fg-3)">
                        Atual: <a href="<%= sobre.curriculo %>" target="_blank" style="color:var(--accent)">ver currículo ↗</a>
                    </p>
                <% } %>
                <input name="curriculo" type="file" accept="application/pdf" id="curriculoInput" class="input-file">
                <span class="hint">Deixe vazio para manter o atual</span>
            </div>

            <!-- Resumo -->
            <div class="campo">
                <label for="resumo">Resumo pessoal <span class="hint">(aparece com efeito typewriter)</span></label>
                <textarea name="resumo" id="resumo" class="textarea" rows="3" required><%= sobre ? sobre.resumo : '' %></textarea>
            </div>

            <!-- Cargo e Empresa -->
            <h3 class="section-title">Atuação</h3>
            <div class="exp-grid">
                <div class="campo">
                    <label for="cargo">Cargo atual</label>
                    <input type="text" id="cargo" name="cargo" class="input" value="<%= sobre ? sobre.cargo : '' %>" required>
                </div>
                <div class="campo">
                    <label for="empresa">Empresa</label>
                    <input type="text" id="empresa" name="empresa" class="input" value="<%= sobre ? sobre.empresa : '' %>" required>
                </div>
            </div>

            <!-- Formação -->
            <h3 class="section-title">Formação</h3>
            <div class="exp-grid">
                <div class="campo">
                    <label for="formacao">Curso</label>
                    <input type="text" id="formacao" name="formacao" class="input" value="<%= sobre ? sobre.formacao : '' %>" required>
                </div>
                <div class="campo">
                    <label for="universidade">Universidade</label>
                    <input type="text" id="universidade" name="universidade" class="input" value="<%= sobre ? sobre.universidade : '' %>" required>
                </div>
            </div>
            <div class="campo">
                <label for="previsaoFormatura">Previsão de conclusão</label>
                <input type="text" id="previsaoFormatura" name="previsaoFormatura" class="input" value="<%= sobre ? sobre.previsaoFormatura : '' %>">
            </div>

            <!-- Tecnologias -->
            <h3 class="section-title">Tecnologias</h3>
            <div class="tag-container" id="techContainer">
                <% if (sobre && sobre.tecnologias) { sobre.tecnologias.forEach(function(tech) { %>
                    <span class="tag"><%= tech %><button type="button">&times;</button></span>
                <% }); } %>
            </div>
            <div class="add-row">
                <input type="text" id="newTech" class="input" placeholder="Ex: Java, Spring Boot...">
                <button type="button" class="btn-add" id="addTechBtn">+ Adicionar</button>
            </div>

            <!-- Experiências -->
            <h3 class="section-title">Experiências</h3>
            <div id="expContainer">
                <% if (sobre && sobre.experiencias) { sobre.experiencias.forEach(function(exp, i) { %>
                    <div class="exp-card">
                        <button type="button" class="btn-remove-exp">Remover</button>
                        <div class="exp-grid">
                            <div class="campo">
                                <label>Empresa</label>
                                <input type="text" class="input exp-empresa" value="<%= exp.empresa %>" required>
                            </div>
                            <div class="campo">
                                <label>Cargo</label>
                                <input type="text" class="input exp-cargo" value="<%= exp.cargo %>" required>
                            </div>
                        </div>
                        <div class="campo" style="margin-top:12px">
                            <label>Período</label>
                            <input type="text" class="input exp-periodo" value="<%= exp.periodo %>" placeholder="Ex: Jan 2024 - Atual">
                        </div>
                        <div class="campo" style="margin-top:12px">
                            <label>Descrição</label>
                            <textarea class="textarea exp-descricao" rows="2"><%= exp.descricao %></textarea>
                        </div>
                    </div>
                <% }); } %>
            </div>
            <button type="button" class="btn-add" id="addExpBtn" style="margin-top:12px">+ Nova experiência</button>

            <button type="submit" class="btn-submit" style="margin-top:20px">Salvar</button>
        </form>
    </div>

    <script src="/js/sobreMimAdmin.js"></script>
</body>

<div class="tweaks-overlay" id="tweaks-overlay"></div>
<aside class="tweaks" id="tweaks" aria-label="Tweaks" role="dialog" aria-modal="true">
  <div class="tweaks-header">
    <h4>// <span class="accent">tweaks</span>.config</h4>
    <button class="tweaks-close-btn" id="tweaks-close">fechar ×</button>
  </div>
  <div class="tweak-row">
    <label>tema<span class="val" id="lbl-theme">dark</span></label>
    <div class="seg" data-key="theme">
      <button data-val="dark">dark</button>
      <button data-val="light">light</button>
    </div>
  </div>
  <div class="tweak-row">
    <label>cor de destaque</label>
    <div class="swatches" data-key="accent">
      <button data-val="lime" title="lime" style="background: oklch(0.82 0.18 130)"></button>
      <button data-val="amber" title="amber" style="background: oklch(0.82 0.17 75)"></button>
      <button data-val="cyan" title="cyan" style="background: oklch(0.78 0.13 210)"></button>
      <button data-val="magenta" title="magenta" style="background: oklch(0.72 0.22 340)"></button>
      <button data-val="red" title="red" style="background: oklch(0.7 0.2 25)"></button>
    </div>
  </div>
  <div class="tweak-row">
    <label>densidade<span class="val" id="lbl-density">airy</span></label>
    <div class="seg" data-key="density">
      <button data-val="compact">compact</button>
      <button data-val="cozy">cozy</button>
      <button data-val="airy">airy</button>
    </div>
  </div>
  <div class="tweak-row">
    <label>background<span class="val" id="lbl-bg">grid</span></label>
    <div class="seg" data-key="bg" style="flex-wrap:wrap">
      <button data-val="off">off</button>
      <button data-val="grid">grid</button>
      <button data-val="matrix">matrix</button>
      <button data-val="constellation">stars</button>
      <button data-val="ascii">ascii</button>
    </div>
  </div>
</aside>

<script src="/js/bgfx.js"></script>
<script src="/js/tweaks-admin.js"></script>
</html>
