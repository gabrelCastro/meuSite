<!DOCTYPE html>
<html lang="pt-br">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <link href="https://fonts.googleapis.com/css2?family=JetBrains+Mono:wght@400;500;600;700&display=swap" rel="stylesheet">
    <link rel="stylesheet" href="/css/form_admin.css">
    <link rel="stylesheet" href="/css/tweaks-panel.css">
    <title>Editar Projeto — Admin</title>
</head>
<body>
    <canvas id="bgfx"></canvas>

    <header class="admin-header">
        <a href="/portfolioAdmin" class="btn-voltar">← portfólio</a>
        <h1>Editar Projeto</h1>
        <button type="button" id="open-tweaks" class="btn-tweaks">⚙</button>
    </header>

    <div class="form-container">
        <form id="projetoForm" class="formulario" data-id="<%= projeto.id %>">
            <div class="campo">
                <label for="titulo">Título</label>
                <input type="text" id="titulo" name="titulo" class="input" required value="<%= projeto.titulo %>">
            </div>

            <div class="campo">
                <label for="descricao">Descrição</label>
                <textarea name="descricao" id="descricao" class="textarea" required><%= projeto.descricao %></textarea>
            </div>

            <div class="campo">
                <label for="tecnologias">Tecnologias</label>
                <input type="text" id="tecnologias" name="tecnologias" class="input" value="<%= projeto.tecnologias.join(', ') %>">
                <span class="hint">Separe com vírgula</span>
            </div>

            <div class="campo">
                <label for="tipo">Tipo <span class="hint">(opcional)</span></label>
                <select id="tipo" name="tipo" class="input">
                    <option value="">— selecione —</option>
                    <option value="profissional" <%=projeto.tipo==='profissional'?'selected':''%>>Profissional</option>
                    <option value="academico" <%=projeto.tipo==='academico'?'selected':''%>>Acadêmico</option>
                    <option value="pessoal" <%=projeto.tipo==='pessoal'?'selected':''%>>Pessoal</option>
                </select>
            </div>

            <div class="campo">
                <label for="papel">Papel / Função <span class="hint">(opcional)</span></label>
                <input type="text" id="papel" name="papel" class="input"
                    value="<%=projeto.papel || ''%>"
                    placeholder="Ex: back-end, full-stack, dados">
            </div>

            <div class="campo">
                <label for="status">Status <span class="hint">(opcional)</span></label>
                <select id="status" name="status" class="input">
                    <option value="">— selecione —</option>
                    <option value="live" <%=projeto.status==='live'?'selected':''%>>Live / Em produção</option>
                    <option value="wip" <%=projeto.status==='wip'?'selected':''%>>Work in progress</option>
                    <option value="archived" <%=projeto.status==='archived'?'selected':''%>>Arquivado / Entregue</option>
                </select>
            </div>

            <div class="campo">
                <label for="githubUrl">Link GitHub <span class="hint">(opcional)</span></label>
                <input type="url" id="githubUrl" name="githubUrl" class="input" value="<%= projeto.githubUrl || '' %>">
            </div>

            <div class="campo">
                <label for="demoUrl">Link Demo <span class="hint">(opcional)</span></label>
                <input type="url" id="demoUrl" name="demoUrl" class="input" value="<%= projeto.demoUrl || '' %>">
            </div>

            <button type="submit" class="btn-submit">Salvar alterações</button>
        </form>
    </div>

    <script src="/js/editarProjeto_projeto.js"></script>
</body>

<%- include('partials/tweaks-panel') %>
</html>
