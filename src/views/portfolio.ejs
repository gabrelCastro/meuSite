<!doctype html>
<html lang="pt-BR">
<head>
<meta charset="utf-8" />
<meta name="viewport" content="width=device-width, initial-scale=1" />
<title>portfólio — gabrel.tech</title>
<link rel="preconnect" href="https://fonts.googleapis.com" />
<link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
<link href="https://fonts.googleapis.com/css2?family=JetBrains+Mono:wght@400;700&family=Geist:wght@400;600&display=swap" rel="stylesheet" />
<link rel="stylesheet" href="/css/site.css" />
<script src="/js/tweaks-default.js"></script>
</head>
<body>

<header class="topbar">
  <div class="topbar-inner">
    <a href="/home" class="brand" aria-label="gabrel.tech">
      <span class="dot" aria-hidden="true"></span>
      <span>gabrel<span class="slash">.</span>tech</span>
    </a>
    <nav class="nav" id="main-nav" aria-label="Principal">
      <a href="/home">home</a>
      <a href="/blog">blog</a>
      <a href="/videos">vídeos</a>
      <a href="/portfolio" aria-current="page">portfólio</a>
      <button class="icon-btn" id="theme-toggle" aria-label="Alternar tema" title="Alternar tema (T)">
        <svg class="ico" viewBox="0 0 24 24" id="theme-icon"><path d="M21 12.8A9 9 0 1 1 11.2 3a7 7 0 0 0 9.8 9.8Z"/></svg>
      </button>
    </nav>
    <button class="nav-toggle" id="nav-toggle" aria-label="Menu" aria-expanded="false">
      <span class="bar"><span></span><span></span><span></span></span>
    </button>
  </div>
</header>

<main class="page">
  <div class="page-head">
    <div class="crumb"><a href="/home">~</a><span class="sep">/</span><span>portfólio</span></div>
    <h1>portfólio<span class="u">_</span><span class="caret" aria-hidden="true"></span></h1>
    <p class="sub">Projetos que desenvolvi — com tecnologias utilizadas e links para código e demo.</p>
    <div class="stats">
      <span><b><%= projetos.length %></b> projetos</span>
    </div>
  </div>

  <%
    const tipoLabels = { profissional: 'profissional', academico: 'acadêmico', pessoal: 'pessoal' };
    const statusLabels = { live: 'em produção', wip: 'work in progress', archived: 'entregue' };
    const allTipos = [...new Set(projetos.map(function(p){ return p.tipo; }).filter(Boolean))].sort();
  %>

  <div class="filters" id="filters">
    <span class="lbl">// filter:</span>
    <button class="chip on" data-tag="all">tudo</button>
    <% allTipos.forEach(function(tipo) { %>
      <button class="chip" data-tag="<%=tipo%>"><%=tipoLabels[tipo]||tipo%></button>
    <% }); %>
  </div>

  <div class="projects" id="projgrid">
    <% if (!projetos || projetos.length === 0) { %>
      <p style="color:var(--fg-3);padding:48px 0;text-align:center;grid-column:1/-1">Nenhum projeto cadastrado ainda.</p>
    <% } else { %>
      <% projetos.forEach(function(projeto, i) { %>
      <article class="project" data-tags="<%= [projeto.tipo, projeto.papel].filter(Boolean).join(' ') %>">
        <div class="head">
          <span class="num">PROJECT_<%- String(i+1).padStart(2,'0') %></span>
          <% if (projeto.status) { %>
            <span class="status <%= projeto.status %>"><%= statusLabels[projeto.status] || projeto.status %></span>
          <% } %>
        </div>
        <h3><%= projeto.titulo %></h3>
        <% if (projeto.papel) { %><p class="role"><%= projeto.papel %></p><% } %>
        <p><%= projeto.descricao %></p>
        <% if (projeto.tecnologias && projeto.tecnologias.length > 0) { %>
        <div class="tech">
          <% projeto.tecnologias.forEach(function(t) { %>
            <span class="t"><%= t %></span>
          <% }); %>
        </div>
        <% } %>
        <div class="links">
          <% if (projeto.githubUrl) { %>
            <a href="<%= projeto.githubUrl %>" target="_blank" rel="noopener">github ↗</a>
          <% } %>
          <% if (projeto.demoUrl) { %>
            <a href="<%= projeto.demoUrl %>" target="_blank" rel="noopener">demo ↗</a>
          <% } %>
          <% if (!projeto.githubUrl && !projeto.demoUrl) { %>
            <span class="muted">código privado</span>
          <% } %>
        </div>
      </article>
      <% }); %>
    <% } %>
  </div>

  <section class="contact-cta" style="margin-top:56px">
    <div>
      <div class="lead">// more.sh</div>
      <h3>tem um projeto em mente?</h3>
      <p>Se tem uma ideia pra construir junto, ou quer saber mais detalhes de qualquer um desses, me chama.</p>
    </div>
    <div class="actions">
      <a class="btn primary" href="mailto:ferreiragabriel589@gmail.com">ferreiragabriel589@gmail.com</a>
      <a class="btn" href="https://github.com/gabrelCastro" target="_blank" rel="noopener">github <span class="arrow">↗</span></a>
    </div>
  </section>

  <footer class="foot">
    <div class="left"><span>© 2025 Gabriel Ferreira de Castro</span></div>
    <div><span class="kbd">T</span> tema</div>
  </footer>
</main>


<canvas id="bgfx" aria-hidden="true"></canvas>
<script src="/js/site.js"></script>
<script src="/js/portfolio-filter.js"></script>
<script src="/js/nav-mobile.js"></script>
</body>
</html>
