<!doctype html>
<html lang="pt-BR">
<head>
<meta charset="utf-8" />
<meta name="viewport" content="width=device-width, initial-scale=1" />
<title><%= video.titulo %> — gabrel.tech</title>
<meta name="description" content="<%= video.descricao || video.titulo %>" />
<link rel="canonical" href="https://gabrel.tech/video/<%= video.slug || video.id %>" />
<meta property="og:type" content="video.other" />
<meta property="og:site_name" content="gabrel.tech" />
<meta property="og:title" content="<%= video.titulo %>" />
<meta property="og:description" content="<%= video.descricao || video.titulo %>" />
<meta property="og:url" content="https://gabrel.tech/video/<%= video.slug || video.id %>" />
<% if (video.img) { %><meta property="og:image" content="<%= video.img %>" /><% } %>
<% if (video.createdAt) { %><meta property="article:published_time" content="<%= new Date(video.createdAt).toISOString() %>" /><% } %>
<meta name="twitter:card" content="<%= video.img ? 'summary_large_image' : 'summary' %>" />
<meta name="twitter:title" content="<%= video.titulo %>" />
<meta name="twitter:description" content="<%= video.descricao || video.titulo %>" />
<% if (video.img) { %><meta name="twitter:image" content="<%= video.img %>" /><% } %>
<%- include('partials/head-common') %>
<link rel="stylesheet" href="/css/post-content.css" />
</head>
<body>

<%- include('partials/nav') %>

<main class="page">
  <div class="page-head">
    <div class="crumb">
      <a href="/home">~</a><span class="sep">/</span><a href="/videos">vídeos</a><span class="sep">/</span><span>video</span>
    </div>
    <% if (video.createdAt) { %>
      <time class="post-date" datetime="<%= new Date(video.createdAt).toISOString() %>">
        <%= new Date(video.createdAt).toLocaleDateString('pt-BR', { day: '2-digit', month: 'long', year: 'numeric' }) %>
      </time>
    <% } %>
    <h1 class="post-title"><%= video.titulo %></h1>
    <% if (video.descricao) { %>
      <p class="sub"><%= video.descricao %></p>
    <% } %>
  </div>

  <div class="video-embed-wrap">
    <%- video.conteudo %>
  </div>

  <% if (video.corpo) { %>
  <article class="post-body prose">
    <%- video.corpo %>
  </article>
  <% } %>

  <div style="margin-top:48px;padding-bottom:16px">
    <a href="/videos" style="color:var(--fg-3);font-size:0.875rem;font-family:var(--mono)">← voltar aos vídeos</a>
  </div>

  <%- include('partials/footer') %>
</main>


<canvas id="bgfx" aria-hidden="true"></canvas>
<script src="/js/site.js"></script>
<script src="/js/nav-mobile.js"></script>
</body>
</html>
