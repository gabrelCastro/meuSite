<!DOCTYPE html>
<html lang="pt-br">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Novo Vídeo — Admin</title>
    <link href="https://fonts.googleapis.com/css2?family=JetBrains+Mono:wght@400;500;600;700&display=swap" rel="stylesheet">
    <link rel="stylesheet" href="/css/form_admin.css">
    <link rel="stylesheet" href="/css/tweaks-panel.css">
</head>
<body>
    <canvas id="bgfx"></canvas>

    <header class="admin-header">
        <a href="/videoAdmin" class="btn-voltar">← vídeos</a>
        <h1>Novo Vídeo</h1>
        <button type="button" id="open-tweaks" class="btn-tweaks">⚙</button>
    </header>

    <div class="form-container">
        <% if (error) { %><div class="form-error"><%= error %></div><% } %>
        <form method="post" action="/video" class="formulario" enctype="multipart/form-data">
            <div class="campo">
                <label for="titulo">Título</label>
                <input type="text" id="titulo" name="titulo" class="input" required placeholder="Título do vídeo">
            </div>

            <div class="campo">
                <label for="imageInput">Imagem de capa</label>
                <input name="imagem" type="file" accept="image/*" id="imageInput" class="input-file">
            </div>

            <div class="campo">
                <label for="conteudo">Link do vídeo</label>
                <input type="url" name="conteudo" id="conteudo" class="input" required
                    placeholder="https://www.youtube.com/watch?v=... ou https://vimeo.com/...">
                <span class="hint">Suporta YouTube e Vimeo</span>
            </div>

            <div class="campo">
                <label for="descricao">Descrição curta <span class="hint">(opcional)</span></label>
                <input type="text" id="descricao" name="descricao" class="input"
                    placeholder="Breve descrição do vídeo" maxlength="500">
            </div>

            <div class="campo">
                <label for="serie">Série <span class="hint">(opcional)</span></label>
                <input type="text" id="serie" name="serie" class="input"
                    placeholder="Ex: Java na prática">
            </div>

            <div class="campo">
                <label for="tags">Tags <span class="hint">(opcional)</span></label>
                <input type="text" id="tags" name="tags" class="input"
                    placeholder="java, spring, arquitetura">
                <span class="hint">Separe com vírgula</span>
            </div>

            <div class="campo">
                <label for="corpo">Conteúdo adicional <span class="hint">(opcional)</span></label>
                <textarea name="corpo" id="corpo"></textarea>
            </div>

            <button type="submit" class="btn-submit">Publicar Vídeo</button>
        </form>
    </div>

    <script src="/tinymce/tinymce.min.js"></script>
    <script src="/js/videoForm.js"></script>
</body>

<%- include('partials/tweaks-panel') %>
</html>
