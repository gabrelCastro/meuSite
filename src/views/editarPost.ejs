<!DOCTYPE html>
<html lang="pt-br">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Editar Post — Admin</title>
    <link href="https://fonts.googleapis.com/css2?family=JetBrains+Mono:wght@400;500;600;700&display=swap" rel="stylesheet">
    <link rel="stylesheet" href="/css/form_admin.css">
    <link rel="stylesheet" href="/css/post-content.css">
    <link rel="stylesheet" href="/css/hljs-theme.css">
    <link rel="stylesheet" href="/css/markdown-editor.css">
    <link rel="stylesheet" href="/css/tweaks-panel.css">
</head>
<body>
    <canvas id="bgfx"></canvas>

    <header class="admin-header">
        <a href="/postAdmin" class="btn-voltar">← posts</a>
        <h1>Editar Post</h1>
        <button type="button" id="open-tweaks" class="btn-tweaks">⚙</button>
    </header>

    <div class="form-container">
        <div class="form-error" id="formError" <% if (!error) { %>hidden<% } %>><%= error || '' %></div>
        <form id="postForm" data-method="PUT" method="post" action="/postEditar/<%=post.id%>" class="formulario" enctype="multipart/form-data">
            <div class="campo">
                <label for="titulo">Título</label>
                <input type="text" id="titulo" name="titulo" class="input" value="<%=post.titulo%>" required>
            </div>

            <div class="campo">
                <label for="descricao">Descrição curta <span class="hint">(opcional)</span></label>
                <input type="text" id="descricao" name="descricao" class="input"
                    value="<%=post.descricao || ''%>" maxlength="500">
            </div>

            <div class="campo">
                <label for="tags">Tags <span class="hint">(opcional)</span></label>
                <input type="text" id="tags" name="tags" class="input"
                    value="<%=(post.tags || []).join(', ')%>">
                <span class="hint">Separe com vírgula</span>
            </div>

            <div class="campo" style="display:flex;align-items:center;gap:10px">
                <input type="checkbox" id="pinned" name="pinned" value="on"
                    <%=post.pinned ? 'checked' : ''%> style="width:16px;height:16px;accent-color:var(--accent)">
                <label for="pinned" style="margin:0;text-transform:none;letter-spacing:0;font-size:0.875rem">Fixar este post no topo do blog</label>
            </div>

            <div class="campo">
                <label for="imageInput">Imagem de capa <span class="hint">(deixe vazio para manter a atual)</span></label>
                <% if (post.img) { %>
                    <img src="<%= post.img %>" alt="Capa atual" style="max-width: 280px; max-height: 160px; border-radius: 6px; border: 1px solid var(--line); margin-bottom: 8px; display: block;">
                <% } %>
                <input name="imagem" type="file" accept="image/*" id="imageInput" class="input-file">
            </div>

            <div class="campo md-field">
                <label for="conteudo">Conteúdo <span class="hint">(Markdown)</span></label>
                <div class="md-toolbar">
                    <button type="button" data-md="bold" title="Negrito (Ctrl+B)"><strong>B</strong></button>
                    <button type="button" data-md="italic" title="Itálico (Ctrl+I)"><em>I</em></button>
                    <button type="button" data-md="h2" title="Título">H2</button>
                    <span class="md-sep"></span>
                    <button type="button" data-md="link" title="Link (Ctrl+K)">↗</button>
                    <button type="button" data-md="image" title="Imagem">⬚</button>
                    <button type="button" data-md="code" title="Código inline">&lt;/&gt;</button>
                    <button type="button" data-md="codeblock" title="Bloco de código">{ }</button>
                    <span class="md-sep"></span>
                    <button type="button" data-md="ul" title="Lista">•</button>
                    <button type="button" data-md="ol" title="Lista numerada">1.</button>
                    <button type="button" data-md="quote" title="Citação">❝</button>
                    <span class="md-toolbar-spacer"></span>
                    <div class="md-view-toggle">
                        <button type="button" data-view="write">Escrever</button>
                        <button type="button" data-view="split" class="active">Split</button>
                        <button type="button" data-view="preview">Preview</button>
                    </div>
                </div>
                <div class="md-editor" data-view="split">
                    <textarea name="conteudo" id="conteudo" class="md-source" placeholder="Escreva em Markdown… arraste ou cole imagens direto aqui."><%= post.conteudo %></textarea>
                    <div class="md-preview"><article class="post-body prose"></article></div>
                </div>
            </div>

            <button type="submit" class="btn-submit">Salvar alterações</button>
        </form>
    </div>

    <script src="/js/markdownEditor.js"></script>
</body>

<%- include('partials/tweaks-panel') %>
</html>
