<!DOCTYPE html>
<html lang="pt-br">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Editar Post — Admin</title>
    <link href="https://fonts.googleapis.com/css2?family=JetBrains+Mono:wght@400;500;600;700&display=swap" rel="stylesheet">
    <link rel="stylesheet" href="/css/form_admin.css">
    <link rel="stylesheet" href="/css/tweaks-panel.css">
</head>
<body>
    <canvas id="bgfx"></canvas>

    <header class="admin-header">
        <a href="/postAdmin" class="btn-voltar">← posts</a>
        <h1>Editar Post</h1>
        <button type="button" id="open-tweaks" class="btn-tweaks">⚙</button>
    </header>

    <div class="form-container">
        <% if (error) { %><div class="form-error"><%= error %></div><% } %>
        <form id="updateVideoForm" method="post" action="/postEditar/<%=post.id%>" class="formulario" enctype="multipart/form-data">
            <div class="campo">
                <label for="titulo">Título</label>
                <input type="text" id="titulo" name="titulo" class="input" value="<%=post.titulo%>" required>
            </div>

            <div class="campo">
                <label for="descricao">Descrição curta <span class="hint">(opcional)</span></label>
                <input type="text" id="descricao" name="descricao" class="input"
                    value="<%=post.descricao || ''%>" maxlength="500">
            </div>

            <div class="campo">
                <label for="tags">Tags <span class="hint">(opcional)</span></label>
                <input type="text" id="tags" name="tags" class="input"
                    value="<%=(post.tags || []).join(', ')%>">
                <span class="hint">Separe com vírgula</span>
            </div>

            <div class="campo" style="display:flex;align-items:center;gap:10px">
                <input type="checkbox" id="pinned" name="pinned" value="on"
                    <%=post.pinned ? 'checked' : ''%> style="width:16px;height:16px;accent-color:var(--accent)">
                <label for="pinned" style="margin:0;text-transform:none;letter-spacing:0;font-size:0.875rem">Fixar este post no topo do blog</label>
            </div>

            <div class="campo">
                <label for="imageInput">Imagem de capa <span class="hint">(deixe vazio para manter a atual)</span></label>
                <% if (post.img) { %>
                    <img src="<%= post.img %>" alt="Capa atual" style="max-width: 280px; max-height: 160px; border-radius: 6px; border: 1px solid var(--line); margin-bottom: 8px; display: block;">
                <% } %>
                <input name="imagem" type="file" accept="image/*" id="imageInput" class="input-file">
            </div>

            <div class="campo">
                <label for="conteudo">Conteúdo</label>
                <textarea name="conteudo" id="conteudo"><%- post.conteudo %></textarea>
            </div>

            <button type="submit" class="btn-submit">Salvar alterações</button>
        </form>
    </div>

    <script src="/tinymce/tinymce.min.js"></script>
    <script src="/js/criarPost.js"></script>
    <script src="/js/post_editar.js"></script>
</body>

<%- include('partials/tweaks-panel') %>
</html>
