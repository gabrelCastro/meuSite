<!DOCTYPE html>
<html lang="pt-br">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <meta name="description" content="<%= post.titulo %>">
    <link href="https://fonts.googleapis.com/css2?family=Inter:wght@400;500;600;700&family=JetBrains+Mono:wght@400;500&display=swap" rel="stylesheet">
    <link rel="stylesheet" type="text/css" href="/css/post.css">
    <title><%= post.titulo %> — meu_blog</title>
</head>
<body>

<header class="cabecalho">
    <canvas id="particles"></canvas>
    <a href="/home" class="brand">meu_blog</a>
    <nav>
        <a href="/home" class="linksNav">home</a>
        <a href="/blog" class="linksNav">meu_blog</a>
        <a href="/videos" class="linksNav">videos</a>
        <a href="/portfolio" class="linksNav">portfólio</a>
    </nav>
</header>

<div class="voltar-wrapper">
    <a href="/blog" class="btn-voltar">← voltar ao blog</a>
</div>

<article class="post-article">
    <header class="post-head">
        <% if (post.createdAt) { %>
            <time class="post-date" datetime="<%= new Date(post.createdAt).toISOString() %>">
                <%= new Date(post.createdAt).toLocaleDateString('pt-BR', { day: '2-digit', month: 'long', year: 'numeric' }) %>
            </time>
        <% } %>
        <h1 class="tituloPost"><%= post.titulo %></h1>
    </header>

    <% if (post.img) { %>
        <figure class="post-cover">
            <img src="<%= post.img %>" alt="Capa do post" loading="eager">
        </figure>
    <% } %>

    <div class="post-content">
        <%- post.conteudo %>
    </div>
</article>

<footer>
    <p class="copyright">2025 | GABRIEL FERREIRA DE CASTRO</p>
</footer>
<script src="/js/particles.js"></script>
</body>
</html>
