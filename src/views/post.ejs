<!doctype html>
<html lang="pt-BR">
<head>
<meta charset="utf-8" />
<meta name="viewport" content="width=device-width, initial-scale=1" />
<title><%= post.titulo %> — gabrel.tech</title>
<meta name="description" content="<%= post.descricao || post.titulo %>" />
<link rel="canonical" href="https://gabrel.tech/post/<%= post.slug || post.id %>" />
<meta property="og:type" content="article" />
<meta property="og:site_name" content="gabrel.tech" />
<meta property="og:title" content="<%= post.titulo %>" />
<meta property="og:description" content="<%= post.descricao || post.titulo %>" />
<meta property="og:url" content="https://gabrel.tech/post/<%= post.slug || post.id %>" />
<% if (post.img) { %><meta property="og:image" content="<%= post.img %>" /><% } %>
<% if (post.createdAt) { %><meta property="article:published_time" content="<%= new Date(post.createdAt).toISOString() %>" /><% } %>
<meta name="twitter:card" content="<%= post.img ? 'summary_large_image' : 'summary' %>" />
<meta name="twitter:title" content="<%= post.titulo %>" />
<meta name="twitter:description" content="<%= post.descricao || post.titulo %>" />
<% if (post.img) { %><meta name="twitter:image" content="<%= post.img %>" /><% } %>
<%- include('partials/head-common') %>
<link rel="stylesheet" href="/css/post-content.css" />
</head>
<body>

<%- include('partials/nav') %>

<main class="page">
  <div class="page-head">
    <div class="crumb">
      <a href="/home">~</a><span class="sep">/</span><a href="/blog">blog</a><span class="sep">/</span><span>post</span>
    </div>
    <% if (post.createdAt) { %>
      <time class="post-date" datetime="<%= new Date(post.createdAt).toISOString() %>">
        <%= new Date(post.createdAt).toLocaleDateString('pt-BR', { day: '2-digit', month: 'long', year: 'numeric' }) %>
      </time>
    <% } %>
    <h1 class="post-title"><%= post.titulo %></h1>
    <% if (post.descricao) { %>
      <p class="sub"><%= post.descricao %></p>
    <% } %>
  </div>

  <% if (post.img) { %>
  <div class="post-cover-wrap">
    <img class="post-cover" src="<%= post.img %>" alt="Capa do post">
  </div>
  <% } %>

  <article class="post-body prose">
    <%- post.conteudo %>
  </article>

  <div style="margin-top:48px;padding-bottom:16px">
    <a href="/blog" style="color:var(--fg-3);font-size:0.875rem;font-family:var(--mono)">← voltar ao blog</a>
  </div>

  <%- include('partials/footer') %>
</main>


<canvas id="bgfx" aria-hidden="true"></canvas>
<script src="/js/site.js"></script>
<script src="/js/nav-mobile.js"></script>
</body>
</html>
