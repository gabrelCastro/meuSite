<!DOCTYPE html>
<html lang="pt-br">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <link href="https://fonts.googleapis.com/css2?family=JetBrains+Mono:wght@400;500;600;700&display=swap" rel="stylesheet">
    <link rel="stylesheet" href="/css/list_admin.css">
    <link rel="stylesheet" href="/css/tweaks-panel.css">
    <title>Portfólio — Admin</title>
</head>
<body>
    <canvas id="bgfx"></canvas>

    <header class="admin-header">
        <a href="/admin" class="btn-voltar">← admin</a>
        <h1>Portfólio</h1>
        <div class="header-right">
            <button type="button" id="open-tweaks" class="btn-tweaks">⚙</button>
            <a href="/criarProjeto" class="btn-novo">+ novo projeto</a>
        </div>
    </header>

    <div class="lista">
        <% if (projetos.length === 0) { %>
            <p class="vazio">Nenhum projeto cadastrado ainda.</p>
        <% } %>
        <% for (let i = 0; i < projetos.length; i++) { %>
        <div class="item">
            <span class="item-titulo"><%= projetos[i].titulo %></span>
            <div class="item-acoes">
                <a href="/projetoEditar/<%= projetos[i].id %>" class="btn-editar">editar</a>
                <a href="#" data-id="<%= projetos[i].id %>" class="btn-deletar" onclick="deletarProjeto(this, event)">deletar</a>
            </div>
        </div>
        <% } %>
    </div>

    <script src="/js/projetoAdmin.js"></script>
</body>

<%- include('partials/tweaks-panel') %>
</html>
