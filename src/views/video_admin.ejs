<!DOCTYPE html>
<html lang="pt-br">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <link href="https://fonts.googleapis.com/css2?family=Inter:wght@400;500;600;700&display=swap" rel="stylesheet">
    <link rel="stylesheet" type="text/css" href="/css/list_admin.css">
    <title>Vídeos — Admin</title>
</head>
<body>
    <header class="admin-header">
        <a href="/admin" class="btn-voltar">← Admin</a>
        <h1>Vídeos</h1>
        <a href="/criarVideo" class="btn-novo">+ Novo Vídeo</a>
    </header>

    <div class="lista">
        <% if (videos.length === 0) { %>
            <p class="vazio">Nenhum vídeo cadastrado ainda.</p>
        <% } %>
        <% for (let i = 0; i < videos.length; i++) { %>
        <div class="item">
            <span class="item-titulo"><%=videos[i].titulo%></span>
            <div class="item-acoes">
                <a href="/videoEditar/<%=videos[i].id%>" class="btn-editar">Editar</a>
                <a href="#" data-id="<%=videos[i].id%>" class="btn-deletar" onclick="deleteVideo(this,event)">Deletar</a>
            </div>
        </div>
        <% } %>
    </div>

    <script src="/js/videoAdmin.js"></script>
</body>
</html>
