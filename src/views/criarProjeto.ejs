<!DOCTYPE html>
<html lang="pt-br">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <link href="https://fonts.googleapis.com/css2?family=JetBrains+Mono:wght@400;500;600;700&display=swap" rel="stylesheet">
    <link rel="stylesheet" href="/css/form_admin.css">
    <link rel="stylesheet" href="/css/tweaks-panel.css">
    <script src="/js/tweaks-default.js"></script>
    <title>Novo Projeto — Admin</title>
</head>
<body>
    <canvas id="bgfx"></canvas>

    <header class="admin-header">
        <a href="/portfolioAdmin" class="btn-voltar">← portfólio</a>
        <h1>Novo Projeto</h1>
        <button type="button" id="open-tweaks" class="btn-tweaks">⚙</button>
    </header>

    <div class="form-container">
        <form id="projetoForm" class="formulario">
            <div class="campo">
                <label for="titulo">Título</label>
                <input type="text" id="titulo" name="titulo" class="input" required placeholder="Nome do projeto">
            </div>

            <div class="campo">
                <label for="descricao">Descrição</label>
                <textarea name="descricao" id="descricao" class="textarea" required placeholder="Descreva o projeto em 1-3 frases..."></textarea>
            </div>

            <div class="campo">
                <label for="tecnologias">Tecnologias</label>
                <input type="text" id="tecnologias" name="tecnologias" class="input" placeholder="Node.js, PostgreSQL, Express">
                <span class="hint">Separe com vírgula</span>
            </div>

            <div class="campo">
                <label for="tipo">Tipo <span class="hint">(opcional)</span></label>
                <select id="tipo" name="tipo" class="input">
                    <option value="">— selecione —</option>
                    <option value="profissional">Profissional</option>
                    <option value="academico">Acadêmico</option>
                    <option value="pessoal">Pessoal</option>
                </select>
            </div>

            <div class="campo">
                <label for="papel">Papel / Função <span class="hint">(opcional)</span></label>
                <input type="text" id="papel" name="papel" class="input"
                    placeholder="Ex: back-end, full-stack, dados">
            </div>

            <div class="campo">
                <label for="status">Status <span class="hint">(opcional)</span></label>
                <select id="status" name="status" class="input">
                    <option value="">— selecione —</option>
                    <option value="live">Live / Em produção</option>
                    <option value="wip">Work in progress</option>
                    <option value="archived">Arquivado / Entregue</option>
                </select>
            </div>

            <div class="campo">
                <label for="githubUrl">Link GitHub <span class="hint">(opcional)</span></label>
                <input type="url" id="githubUrl" name="githubUrl" class="input" placeholder="https://github.com/...">
            </div>

            <div class="campo">
                <label for="demoUrl">Link Demo <span class="hint">(opcional)</span></label>
                <input type="url" id="demoUrl" name="demoUrl" class="input" placeholder="https://...">
            </div>

            <button type="submit" class="btn-submit">Publicar Projeto</button>
        </form>
    </div>

    <script src="/js/criarProjeto_projeto.js"></script>
</body>

<div class="tweaks-overlay" id="tweaks-overlay"></div>
<aside class="tweaks" id="tweaks" aria-label="Tweaks" role="dialog" aria-modal="true">
  <div class="tweaks-header">
    <h4>// <span class="accent">tweaks</span>.config</h4>
    <button class="tweaks-close-btn" id="tweaks-close">fechar ×</button>
  </div>
  <div class="tweak-row">
    <label>tema<span class="val" id="lbl-theme">dark</span></label>
    <div class="seg" data-key="theme">
      <button data-val="dark">dark</button>
      <button data-val="light">light</button>
    </div>
  </div>
  <div class="tweak-row">
    <label>cor de destaque</label>
    <div class="swatches" data-key="accent">
      <button data-val="lime" title="lime" style="background: oklch(0.82 0.18 130)"></button>
      <button data-val="amber" title="amber" style="background: oklch(0.82 0.17 75)"></button>
      <button data-val="cyan" title="cyan" style="background: oklch(0.78 0.13 210)"></button>
      <button data-val="magenta" title="magenta" style="background: oklch(0.72 0.22 340)"></button>
      <button data-val="red" title="red" style="background: oklch(0.7 0.2 25)"></button>
    </div>
  </div>
  <div class="tweak-row">
    <label>densidade<span class="val" id="lbl-density">airy</span></label>
    <div class="seg" data-key="density">
      <button data-val="compact">compact</button>
      <button data-val="cozy">cozy</button>
      <button data-val="airy">airy</button>
    </div>
  </div>
  <div class="tweak-row">
    <label>background<span class="val" id="lbl-bg">grid</span></label>
    <div class="seg" data-key="bg" style="flex-wrap:wrap">
      <button data-val="off">off</button>
      <button data-val="grid">grid</button>
      <button data-val="matrix">matrix</button>
      <button data-val="constellation">stars</button>
      <button data-val="ascii">ascii</button>
    </div>
  </div>
</aside>

<script src="/js/bgfx.js"></script>
<script src="/js/tweaks-admin.js"></script>
</html>
