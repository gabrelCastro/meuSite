<!doctype html>
<html lang="pt-BR">
<head>
<meta charset="utf-8" />
<meta name="viewport" content="width=device-width, initial-scale=1" />
<title>blog — gabrel.tech</title>
<link rel="preconnect" href="https://fonts.googleapis.com" />
<link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
<link href="https://fonts.googleapis.com/css2?family=JetBrains+Mono:wght@400;500;600;700&family=Geist:wght@400;500;600&display=swap" rel="stylesheet" />
<link rel="stylesheet" href="/css/site.css" />
<link rel="stylesheet" href="/css/responsive.css" />
<script src="/js/tweaks-default.js"></script>
</head>
<body>

<header class="topbar">
  <div class="topbar-inner">
    <a href="/home" class="brand" aria-label="gabrel.tech">
      <span class="dot" aria-hidden="true"></span>
      <span>gabrel<span class="slash">.</span>tech</span>
    </a>
    <nav class="nav" id="main-nav" aria-label="Principal">
      <a href="/home">home</a>
      <a href="/blog" aria-current="page">blog</a>
      <a href="/videos">vídeos</a>
      <a href="/portfolio">portfólio</a>
      <button class="icon-btn" id="theme-toggle" aria-label="Alternar tema" title="Alternar tema (T)">
        <svg class="ico" viewBox="0 0 24 24" id="theme-icon"><path d="M21 12.8A9 9 0 1 1 11.2 3a7 7 0 0 0 9.8 9.8Z"/></svg>
      </button>
    </nav>
    <button class="nav-toggle" id="nav-toggle" aria-label="Menu" aria-expanded="false">
      <span class="bar"><span></span><span></span><span></span></span>
    </button>
  </div>
</header>

<main class="page">
  <div class="page-head">
    <div class="crumb">
      <a href="/home">~</a><span class="sep">/</span><span>blog</span>
    </div>
    <h1>meu<span class="u">_</span>blog<span class="caret" aria-hidden="true"></span></h1>
    <p class="sub">Onde compartilho o que estou aprendendo sobre programação, arquitetura e o dia-a-dia de engenharia.</p>
    <div class="stats">
      <span><b><%= posts.length %></b> posts</span>
    </div>
  </div>

  <%
    const allTags = [...new Set(posts.flatMap(function(p){ return p.tags || []; }))].sort();
    const pinnedPost = posts.find(function(p){ return p.pinned; });
    const regularPosts = posts.filter(function(p){ return !p.pinned; });
  %>

  <div class="filters" id="filters">
    <span class="lbl">// filter:</span>
    <button class="chip on" data-tag="all">tudo</button>
    <% allTags.forEach(function(tag) { %>
      <button class="chip" data-tag="<%=tag%>"><%=tag%></button>
    <% }); %>
    <label class="search">
      <svg class="ico" viewBox="0 0 24 24"><circle cx="11" cy="11" r="7"/><path d="m20 20-3.5-3.5"/></svg>
      <input type="search" id="q" placeholder="busca..." />
    </label>
  </div>

  <% if (pinnedPost) { %>
  <article class="pinned">
    <span class="k">// pinned</span>
    <div>
      <h3><a href="/post/<%= pinnedPost.id %>"><%= pinnedPost.titulo %></a></h3>
      <% if (pinnedPost.descricao) { %><p><%= pinnedPost.descricao %></p><% } %>
    </div>
    <a class="go" href="/post/<%= pinnedPost.id %>">ler post →</a>
  </article>
  <% } %>

  <div class="posts" id="posts">
    <% if (!posts || posts.length === 0) { %>
      <p style="color:var(--fg-3);padding:48px 0;text-align:center">Nenhum post publicado ainda.</p>
    <% } else { %>
      <% regularPosts.forEach(function(p) { %>
      <article class="post" data-tags="<%= (p.tags || []).join(' ') %>">
        <div class="date"><%= new Date(p.createdAt).toISOString().slice(0,10) %></div>
        <div class="body">
          <h3><a href="/post/<%= p.id %>"><%= p.titulo %></a></h3>
          <% if (p.descricao) { %><p><%= p.descricao %></p><% } %>
          <% if (p.tags && p.tags.length > 0) { %>
          <div class="meta-tags">
            <% p.tags.forEach(function(tag){ %><span class="tag"><%=tag%></span><% }); %>
          </div>
          <% } %>
        </div>
        <span class="read"><a href="/post/<%= p.id %>">ler →</a></span>
      </article>
      <% }); %>
    <% } %>
  </div>

  <footer class="foot">
    <div class="left"><span>© 2025 Gabriel Ferreira de Castro</span></div>
    <div><span class="kbd">T</span> tema</div>
  </footer>
</main>


<canvas id="bgfx" aria-hidden="true"></canvas>
<script src="/js/site.js"></script>
<script src="/js/blog-filter.js"></script>
<script src="/js/nav-mobile.js"></script>
</body>
</html>
