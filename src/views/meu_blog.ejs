<!DOCTYPE html>
<html lang="pt-br">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <link href="https://fonts.googleapis.com/css2?family=Inter:wght@400;500;600;700&display=swap" rel="stylesheet">
    <link rel="stylesheet" type="text/css" href="/css/blog.css">
    <title>meu_blog</title>
</head>
<body>
    <header class="cabecalho">
        <h1>meu_blog</h1>
        <nav>
            <a href="/home" class="linksNav">home</a>
            <a href="/blog" class="linksNav">meu_blog</a>
            <a href="/explicando" class="linksNav">explicando</a>
            <a href="/portfolio" class="linksNav">portfólio</a>
        </nav>
    </header>

    <div class="posts">
        <% for (let i = 0; i < posts.length; i++) { %>
            <div class="post" id="<%=posts[i].id%>">
                <img src="<%= posts[i].img %>" alt="Imagem do post">
                <div class="post-title">
                    <h2><%= posts[i].titulo %></h2>
                </div>
            </div>
        <% } %>
    </div>

    <footer>
        <p class="copyright">2025 | GABRIEL FERREIRA DE CASTRO</p>
    </footer>

    <script src="/js/blog.js"></script>
</body>
</html>
