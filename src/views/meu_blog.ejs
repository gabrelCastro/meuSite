<!doctype html>
<html lang="pt-BR">
<head>
<meta charset="utf-8" />
<meta name="viewport" content="width=device-width, initial-scale=1" />
<title>blog — gabrel.tech</title>
<meta name="description" content="Blog de Gabriel Ferreira de Castro sobre programação, arquitetura de software e o dia-a-dia de engenharia." />
<link rel="canonical" href="https://gabrel.tech/blog" />
<meta property="og:type" content="website" />
<meta property="og:site_name" content="gabrel.tech" />
<meta property="og:title" content="blog — gabrel.tech" />
<meta property="og:description" content="Blog de Gabriel Ferreira de Castro sobre programação, arquitetura de software e o dia-a-dia de engenharia." />
<meta property="og:url" content="https://gabrel.tech/blog" />
<meta name="twitter:card" content="summary" />
<meta name="twitter:title" content="blog — gabrel.tech" />
<meta name="twitter:description" content="Blog de Gabriel Ferreira de Castro sobre programação, arquitetura de software e o dia-a-dia de engenharia." />
<%- include('partials/head-common') %>
</head>
<body>

<%- include('partials/nav') %>

<main class="page">
  <div class="page-head">
    <div class="crumb">
      <a href="/home">~</a><span class="sep">/</span><span>blog</span>
    </div>
    <h1>meu<span class="u">_</span>blog<span class="caret" aria-hidden="true"></span></h1>
    <p class="sub">Onde compartilho o que estou aprendendo sobre programação, arquitetura e o dia-a-dia de engenharia.</p>
    <div class="stats">
      <span><b><%= posts.length %></b> posts</span>
    </div>
  </div>

  <%
    const allTags = [...new Set(posts.flatMap(function(p){ return p.tags || []; }))].sort();
    const pinnedPost = posts.find(function(p){ return p.pinned; });
    const regularPosts = posts.filter(function(p){ return !p.pinned; });
  %>

  <div class="filters" id="filters">
    <span class="lbl">// filter:</span>
    <button class="chip on" data-tag="all">tudo</button>
    <% allTags.forEach(function(tag) { %>
      <button class="chip" data-tag="<%=tag%>"><%=tag%></button>
    <% }); %>
    <label class="search">
      <svg class="ico" viewBox="0 0 24 24"><circle cx="11" cy="11" r="7"/><path d="m20 20-3.5-3.5"/></svg>
      <input type="search" id="q" placeholder="busca..." />
    </label>
  </div>

  <% if (pinnedPost) { %>
  <article class="pinned">
    <span class="k">// pinned</span>
    <div>
      <h3><a href="/post/<%= pinnedPost.slug || pinnedPost.id %>"><%= pinnedPost.titulo %></a></h3>
      <% if (pinnedPost.descricao) { %><p><%= pinnedPost.descricao %></p><% } %>
    </div>
    <a class="go" href="/post/<%= pinnedPost.slug || pinnedPost.id %>">ler post →</a>
  </article>
  <% } %>

  <div class="posts" id="posts">
    <% if (!posts || posts.length === 0) { %>
      <p style="color:var(--fg-3);padding:48px 0;text-align:center">Nenhum post publicado ainda.</p>
    <% } else { %>
      <% regularPosts.forEach(function(p) { %>
      <article class="post" data-tags="<%= (p.tags || []).join(' ') %>">
        <div class="date"><%= new Date(p.createdAt).toISOString().slice(0,10) %></div>
        <div class="body">
          <h3><a href="/post/<%= p.slug || p.id %>"><%= p.titulo %></a></h3>
          <% if (p.descricao) { %><p><%= p.descricao %></p><% } %>
          <% if (p.tags && p.tags.length > 0) { %>
          <div class="meta-tags">
            <% p.tags.forEach(function(tag){ %><span class="tag"><%=tag%></span><% }); %>
          </div>
          <% } %>
        </div>
        <span class="read"><a href="/post/<%= p.slug || p.id %>">ler →</a></span>
      </article>
      <% }); %>
    <% } %>
  </div>

  <%- include('partials/footer') %>
</main>


<canvas id="bgfx" aria-hidden="true"></canvas>
<script src="/js/site.js"></script>
<script src="/js/blog-filter.js"></script>
<script src="/js/nav-mobile.js"></script>
</body>
</html>
