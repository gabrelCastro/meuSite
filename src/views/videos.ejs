<!doctype html>
<html lang="pt-BR">
<head>
<meta charset="utf-8" />
<meta name="viewport" content="width=device-width, initial-scale=1" />
<title>vídeos — gabrel.tech</title>
<meta name="description" content="Vídeos de Gabriel Ferreira de Castro sobre programação e tecnologia — do fundamento ao que uso no trabalho." />
<link rel="canonical" href="https://gabrel.tech/videos" />
<meta property="og:type" content="website" />
<meta property="og:site_name" content="gabrel.tech" />
<meta property="og:title" content="vídeos — gabrel.tech" />
<meta property="og:description" content="Vídeos de Gabriel Ferreira de Castro sobre programação e tecnologia — do fundamento ao que uso no trabalho." />
<meta property="og:url" content="https://gabrel.tech/videos" />
<meta name="twitter:card" content="summary" />
<meta name="twitter:title" content="vídeos — gabrel.tech" />
<meta name="twitter:description" content="Vídeos de Gabriel Ferreira de Castro sobre programação e tecnologia — do fundamento ao que uso no trabalho." />
<%- include('partials/head-common') %>
</head>
<body>

<%- include('partials/nav') %>

<main class="page">
  <div class="page-head">
    <div class="crumb"><a href="/home">~</a><span class="sep">/</span><span>vídeos</span></div>
    <h1>vídeos<span class="u">_</span><span class="caret" aria-hidden="true"></span></h1>
    <p class="sub">Vídeos onde mostro e exercito didática em conteúdos que aprendi e achei interessante repassar — do fundamento ao que uso no trabalho.</p>
    <div class="stats">
      <span><b><%= videos.length %></b> vídeos</span>
    </div>
  </div>

  <%
    const allVideoTags = [...new Set(videos.flatMap(function(v){ return v.tags || []; }))].sort();
    const series = [...new Set(videos.map(function(v){ return v.serie; }).filter(Boolean))];
  %>

  <% if (series.length > 0) { %>
  <div class="series-strip">
    <% series.forEach(function(s) { %>
    <div class="series">
      <span class="k">// series/</span>
      <h3><%=s%></h3>
      <span class="count"><%=videos.filter(function(v){ return v.serie===s; }).length%> vídeos</span>
    </div>
    <% }); %>
  </div>
  <% } %>

  <div class="filters">
    <span class="lbl">// filter:</span>
    <button class="chip on" data-tag="all">tudo</button>
    <% allVideoTags.forEach(function(tag) { %>
      <button class="chip" data-tag="<%=tag%>"><%=tag%></button>
    <% }); %>
  </div>

  <div class="video-grid" id="vgrid">
    <% if (!videos || videos.length === 0) { %>
      <p style="color:var(--fg-3);padding:48px 0;text-align:center;grid-column:1/-1">Nenhum vídeo publicado ainda.</p>
    <% } else { %>
      <% videos.forEach(function(v) { %>
      <a class="vcard" href="/video/<%= v.slug || v.id %>" aria-label="<%= v.titulo %>" data-tags="<%= (v.tags || []).join(' ') %>">
        <div class="thumb">
          <% if (v.img) { %>
            <img src="<%= v.img %>" alt="" loading="lazy" style="width:100%;height:100%;object-fit:cover;position:absolute;inset:0">
          <% } %>
          <span class="play">
            <svg width="18" height="18" viewBox="0 0 24 24" fill="currentColor"><path d="M8 5v14l11-7z"/></svg>
          </span>
        </div>
        <div class="info">
          <h3><%= v.titulo %></h3>
          <% if (v.descricao) { %><p><%= v.descricao %></p><% } %>
          <div class="foot">
            <% if (v.serie) { %><span>// <%=v.serie%></span><% } %>
            <% if (v.createdAt) { %>
              <time datetime="<%= new Date(v.createdAt).toISOString() %>">
                <%= new Date(v.createdAt).toLocaleDateString('pt-BR', { day: '2-digit', month: 'short', year: 'numeric' }) %>
              </time>
            <% } %>
          </div>
        </div>
      </a>
      <% }); %>
    <% } %>
  </div>

  <%- include('partials/footer') %>
</main>


<canvas id="bgfx" aria-hidden="true"></canvas>
<script src="/js/site.js"></script>
<script src="/js/videos-filter.js"></script>
<script src="/js/nav-mobile.js"></script>
</body>
</html>
