<!DOCTYPE html>
<html lang="pt-br">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <meta name="description" content="Videos — conteúdo sobre programação e tecnologia">
    <link href="https://fonts.googleapis.com/css2?family=Inter:wght@400;500;600;700&family=JetBrains+Mono:wght@400;500&display=swap" rel="stylesheet">
    <link rel="stylesheet" type="text/css" href="/css/videos.css">
    <title>videos</title>
</head>
<body>
    <header class="cabecalho">
        <canvas id="particles"></canvas>
        <h1 class="page-title">videos</h1>
        <nav>
            <a href="/home" class="linksNav">home</a>
            <a href="/blog" class="linksNav">meu_blog</a>
            <a href="/videos" class="linksNav">videos</a>
            <a href="/portfolio" class="linksNav">portfólio</a>
        </nav>
    </header>

    <main class="videos">
        <% if (!videos || videos.length === 0) { %>
            <p class="videos-empty">Nenhum vídeo publicado ainda.</p>
        <% } else { %>
            <% videos.forEach(function(v) { %>
                <a href="/video/<%= v.id %>" class="video" aria-label="<%= v.titulo %>">
                    <div class="separacaoImagem">
                        <img src="<%= v.img %>" alt="" loading="lazy">
                        <div class="play-overlay">
                            <svg xmlns="http://www.w3.org/2000/svg" width="40" height="40" viewBox="0 0 24 24" fill="currentColor">
                                <circle cx="12" cy="12" r="10" fill="rgba(0,0,0,0.55)"/>
                                <polygon points="10 8 16 12 10 16 10 8" fill="white"/>
                            </svg>
                        </div>
                    </div>
                    <div class="video-info">
                        <% if (v.createdAt) { %>
                            <time class="video-date" datetime="<%= new Date(v.createdAt).toISOString() %>">
                                <%= new Date(v.createdAt).toLocaleDateString('pt-BR', { day: '2-digit', month: 'short', year: 'numeric' }) %>
                            </time>
                        <% } %>
                        <h2><%= v.titulo %></h2>
                        <% if (v.descricao) { %>
                            <p class="video-desc"><%= v.descricao %></p>
                        <% } %>
                    </div>
                </a>
            <% }); %>
        <% } %>
    </main>

    <footer>
        <p class="copyright">2025 | GABRIEL FERREIRA DE CASTRO</p>
    </footer>

    <script src="/js/particles.js"></script>
</body>
</html>
