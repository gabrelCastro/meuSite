<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <link href="https://fonts.googleapis.com/css2?family=Inter:wght@400;500;600;700&family=JetBrains+Mono:wght@400;500&display=swap" rel="stylesheet">
    <link rel="stylesheet" type="text/css" href="/css/home.css">
    <title>Home</title>
</head>
<body>
    <header class="cabecalho">
        <canvas id="particles"></canvas>
        <h1 class = "meu_Nome">Gabriel_Ferreira<br>de_Castro</h1>

        <nav>
            <a href="/home" class="linksNav">home</a>
            <a href="/blog" class="linksNav">meu_blog</a>
            <a href="/explicando" class="linksNav">explicando</a>
            <a href="/portfolio" class="linksNav">portfólio</a>
        </nav>
        <div class="gl">
            <div class="publi">
                <a href="https://github.com/gabrelCastro">
                <img class ="logos" src="/img/pngegg.png" alt="github"></a>
                <a href="https://github.com/gabrelCastro" class = "Links">meu github</a>
            </div>

            <div class="publi">
                <a href="https://www.linkedin.com/in/gabriel-ferreira-30a855217/">
                <img class ="logos" src="/img/linkedin.png" alt="github"></a>
                <a href="https://www.linkedin.com/in/gabriel-ferreira-30a855217/" class = "Links">meu linkedin</a>
            </div>
        </div>

        <h1 class="fraseIconica">Exploring The World Thought the code;</h1>

    </header>

    <!-- ══ SOBRE MIM ══════════════════════════════════ -->
    <% if (sobre) { %>
    <section class="about">

        <!-- ROW 1: Hero (split assimétrico) + Educação ao lado -->
        <div class="about__row about__row--top">

            <div class="about__hero reveal">
                <div class="about__photo-wrapper">
                    <div class="about__photo-halo"></div>
                    <div class="about__photo-frame">
                        <img class="about__photo" src="<%= sobre.foto || '/img/minha foto.jpeg.jpg' %>" alt="Foto de perfil">
                    </div>
                    <span class="about__photo-deco about__photo-deco--tl"></span>
                    <span class="about__photo-deco about__photo-deco--br"></span>
                </div>
                <div class="about__intro">
                    <span class="about__kicker">// sobre_mim</span>
                    <h2 class="about__title">Desenvolvedor<span class="cursor">_</span></h2>
                    <div class="about__badge">
                        <span class="about__badge-dot"></span>
                        <%= sobre.cargo %> @ <%= sobre.empresa %>
                    </div>
                    <p class="about__resumo" id="sobreMim"></p>
                </div>
            </div>

            <aside class="about__edu-card reveal">
                <div class="about__edu-header">
                    <svg xmlns="http://www.w3.org/2000/svg" width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
                        <path d="M22 10v6M2 10l10-5 10 5-10 5z"/><path d="M6 12v5c0 1.1 2.7 3 6 3s6-1.9 6-3v-5"/>
                    </svg>
                    <span>formação_</span>
                </div>
                <h4 class="about__edu-course"><%= sobre.formacao %></h4>
                <p class="about__edu-uni"><%= sobre.universidade %></p>
                <% if (sobre.previsaoFormatura) { %>
                    <div class="about__edu-meta">
                        <span class="about__edu-meta-label">conclusão</span>
                        <span class="about__edu-meta-value"><%= sobre.previsaoFormatura %></span>
                    </div>
                <% } %>
            </aside>

        </div>

        <!-- ROW 2: Tech strip (faixa horizontal) -->
        <% if (sobre.tecnologias && sobre.tecnologias.length > 0) { %>
        <div class="about__tech-strip reveal">
            <div class="about__tech-label">
                <svg xmlns="http://www.w3.org/2000/svg" width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
                    <polyline points="16 18 22 12 16 6"/><polyline points="8 6 2 12 8 18"/>
                </svg>
                tech_stack
            </div>
            <div class="about__techs">
                <% sobre.tecnologias.forEach(function(tech) { %>
                    <span class="about__tech-pill"><%= tech %></span>
                <% }); %>
            </div>
        </div>
        <% } %>

        <!-- ROW 3: Timeline (full width) -->
        <% if (sobre.experiencias && sobre.experiencias.length > 0) { %>
        <div class="about__timeline-wrap reveal">
            <h3 class="about__section-title">
                <svg xmlns="http://www.w3.org/2000/svg" width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
                    <rect x="2" y="7" width="20" height="14" rx="2" ry="2"/><path d="M16 21V5a2 2 0 0 0-2-2h-4a2 2 0 0 0-2 2v16"/>
                </svg>
                trajetória_
            </h3>
            <div class="timeline">
                <% sobre.experiencias.forEach(function(exp, i) { %>
                    <div class="timeline__item reveal" style="--delay: <%= i * 0.1 %>s">
                        <div class="timeline__marker">
                            <span class="timeline__dot<%= i === 0 ? ' timeline__dot--active' : '' %>"></span>
                            <% if (i < sobre.experiencias.length - 1) { %>
                                <span class="timeline__line"></span>
                            <% } %>
                        </div>
                        <div class="timeline__content">
                            <div class="timeline__header">
                                <strong class="timeline__role"><%= exp.cargo %></strong>
                                <span class="timeline__period"><%= exp.periodo %></span>
                            </div>
                            <span class="timeline__company"><%= exp.empresa %></span>
                            <% if (exp.descricao) { %>
                                <p class="timeline__desc"><%= exp.descricao %></p>
                            <% } %>
                        </div>
                    </div>
                <% }); %>
            </div>
        </div>
        <% } %>

    </section>
    <% } else { %>
    <!-- Fallback quando não há dados cadastrados -->
    <div class="sobreMim reveal">
        <h1 class="titutoAbout">Sobre mim</h1>
        <div class="fotoTexto">
            <p class="texto" id="sobreMim"></p>
            <div class="circuloImagem">
                <img class="minhaFoto" src="/img/minha foto.jpeg.jpg" alt="">
            </div>
        </div>
    </div>
    <% } %>

    <section class="conheca reveal">
        <h1 class="titutoAbout" id="conheca">Conheça_</h1>
        <div class="conheca-grid">

            <a href="/explicando" class="conheca-card">
                <div class="conheca-banner conheca-banner--video">
                    <svg xmlns="http://www.w3.org/2000/svg" width="48" height="48" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round">
                        <circle cx="12" cy="12" r="10"/><polygon points="10 8 16 12 10 16 10 8"/>
                    </svg>
                </div>
                <div class="conheca-body">
                    <h3>Explicando</h3>
                    <p>Vídeos onde mostro e exercito didática em conteúdos que aprendi e achei interessante repassar.</p>
                    <span class="conheca-cta">Assistir vídeos →</span>
                </div>
            </a>

            <a href="/blog" class="conheca-card">
                <div class="conheca-banner conheca-banner--blog">
                    <svg xmlns="http://www.w3.org/2000/svg" width="48" height="48" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round">
                        <path d="M14 2H6a2 2 0 0 0-2 2v16a2 2 0 0 0 2 2h12a2 2 0 0 0 2-2V8z"/><polyline points="14 2 14 8 20 8"/><line x1="16" y1="13" x2="8" y2="13"/><line x1="16" y1="17" x2="8" y2="17"/><polyline points="10 9 9 9 8 9"/>
                    </svg>
                </div>
                <div class="conheca-body">
                    <h3>Meu Blog</h3>
                    <p>Onde mostro o que estou aprendendo e o que já sei sobre programação e tecnologia.</p>
                    <span class="conheca-cta">Ler posts →</span>
                </div>
            </a>

            <a href="/portfolio" class="conheca-card">
                <div class="conheca-banner conheca-banner--portfolio">
                    <svg xmlns="http://www.w3.org/2000/svg" width="48" height="48" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round">
                        <polyline points="16 18 22 12 16 6"/><polyline points="8 6 2 12 8 18"/>
                    </svg>
                </div>
                <div class="conheca-body">
                    <h3>Portfólio</h3>
                    <p>Projetos que desenvolvi, com tecnologias utilizadas e links para código e demo.</p>
                    <span class="conheca-cta">Ver projetos →</span>
                </div>
            </a>

        </div>
    </section>

    <footer>
        <p class="copyright">2025 | GABRIEL FERREIRA DE CASTRO</p>
    </footer>


    <script src="/js/script.js"<% if (sobre) { %> data-resumo="<%= sobre.resumo.replace(/"/g, '&quot;') %>"<% } %>></script>
    <script src="/js/particles.js"></script>
</body>
</html>
